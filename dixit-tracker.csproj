<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>DixitTracker</RootNamespace>
    <AssemblyName>DixitTracker</AssemblyName>
    <!-- GitHub Pages settings -->
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <!-- Publish wwwroot contents directly to publish output -->
    <StaticWebAssetBasePath>/dixit-tracker/</StaticWebAssetBasePath>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="8.0.0" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="8.0.0" PrivateAssets="all" />
    <PackageReference Include="Microsoft.JSInterop" Version="8.0.0" />
  </ItemGroup>
</Project>
